# EchoLine Environment Variables
# Task: SB12
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# For local development: make dev-up sets most of these via Docker Compose.
# For production: use a secrets manager (AWS Secrets Manager, HashiCorp Vault).
#
# Run all services:
#   make dev-up
#   source .env
#   make api-run
#   make worker-run

# ─── Required: Database ───────────────────────────────────────────────────────

# PostgreSQL connection string
# Format: postgres://user:password@host:port/dbname?sslmode=...
# Development: sslmode=disable (no TLS)
# Production: sslmode=require (enforce TLS)
DATABASE_URL=postgres://echoline:echoline@localhost:5432/echoline?sslmode=disable

# ─── Required: Auth ───────────────────────────────────────────────────────────

# JWT signing secret — MUST be at least 32 characters in production
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-in-production-use-at-least-32-chars

# JWT access token expiry (Go duration syntax)
JWT_EXPIRY=15m

# JWT refresh token expiry
JWT_REFRESH_EXPIRY=7d

# ─── Required: Redis ──────────────────────────────────────────────────────────

# Redis connection address (host:port)
REDIS_ADDR=localhost:6379

# Redis password (leave empty for no auth in development)
REDIS_PASSWORD=

# Redis database number (0-15)
REDIS_DB=0

# ─── Required: Message Queue (Kafka / Redpanda) ───────────────────────────────

# Comma-separated list of Kafka broker addresses
KAFKA_BROKERS=localhost:9092

# Kafka topic for message events
KAFKA_TOPIC_MESSAGES=message.created

# Kafka topic for delivery ACK events
KAFKA_TOPIC_DELIVERY=delivery.ack

# Kafka consumer group ID for the worker service
KAFKA_CONSUMER_GROUP=echoline-worker

# ─── Required: Media Storage (S3 / MinIO) ────────────────────────────────────

# S3 endpoint (use MinIO for local dev)
# Production: leave empty to use AWS S3 standard endpoint
S3_ENDPOINT=http://localhost:9000

# S3 region (for AWS; unused for MinIO)
S3_REGION=us-east-1

# S3 access key
# Production: use IAM role with least-privilege S3 policy
S3_ACCESS_KEY=minio

# S3 secret key
S3_SECRET_KEY=minio123

# S3 bucket name (must exist; created by `make dev-up`)
S3_BUCKET=echoline

# Presigned URL expiry (Go duration syntax)
S3_PRESIGN_EXPIRY=1h

# ─── Optional: Observability ─────────────────────────────────────────────────

# Port for Prometheus metrics endpoint (/metrics)
METRICS_PORT=9090

# OpenTelemetry OTLP endpoint (for distributed tracing)
# Leave empty to disable OTel export
# Example: http://localhost:4317 (Jaeger OTLP gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=

# OTel service name (appears in traces)
OTEL_SERVICE_NAME=echoline-api

# OTel sampling rate (0.0 to 1.0)
# 1.0 = 100% (development); 0.01 = 1% (production high-volume paths)
OTEL_SAMPLING_RATIO=1.0

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json (production), text (development)
LOG_FORMAT=json

# ─── Optional: Rate Limiting ─────────────────────────────────────────────────

# Max login attempts per IP per minute
RATE_LIMIT_LOGIN=5

# Max message sends per user per minute
RATE_LIMIT_MESSAGE_SEND=60

# Max register attempts per IP per 10 minutes
RATE_LIMIT_REGISTER=3

# ─── Optional: Outbox Worker ─────────────────────────────────────────────────

# How often the outbox worker polls for pending events (Go duration)
OUTBOX_POLL_INTERVAL=100ms

# Max batch size per outbox drain cycle
OUTBOX_BATCH_SIZE=10

# Max attempts before moving to DLQ
OUTBOX_MAX_ATTEMPTS=5

# ─── Optional: Fanout ────────────────────────────────────────────────────────

# Member count threshold for sync vs async fanout
# Groups <= threshold use synchronous hub fanout
# Groups > threshold use async worker fanout
FANOUT_SYNC_THRESHOLD=256

# ─── Optional: Server ────────────────────────────────────────────────────────

# API server listen address
API_ADDR=:8080

# WebSocket ping interval (Go duration)
WS_PING_INTERVAL=30s

# WebSocket read timeout (connection closed if no pong received)
WS_READ_TIMEOUT=90s

# Max WebSocket message size in bytes
WS_MAX_MESSAGE_SIZE=1048576

# ─── Optional: Notifications (future) ────────────────────────────────────────

# FCM server key (for Android push notifications)
# FCM_SERVER_KEY=

# APNs certificate path (for iOS push notifications)
# APNS_CERT_PATH=

# APNs certificate password
# APNS_CERT_PASSWORD=

# ─── Optional: Search ────────────────────────────────────────────────────────

# OpenSearch endpoint (leave empty to use Postgres tsvector)
OPENSEARCH_URL=
# OPENSEARCH_ENDPOINT=http://localhost:9200

# ─── Optional: Admin / Integrations ──────────────────────────────────────────

# Comma-separated user UUIDs with admin access
ADMIN_USER_IDS=

# Outbound webhook URL for message.created events
WEBHOOK_URL=

# Enable GraphiQL at GET /graphql
GRAPHIQL=false

# Prototype only: allow clients to create/settle payment ledger (default false)
PAYMENT_SELF_SERVE=false

# Sentry DSN (stub logs when set)
SENTRY_DSN=

# ─── Development only ────────────────────────────────────────────────────────

# Seed the database with test users and conversations
# Set to 1 to run seed on startup (development only)
AUTO_SEED=0

# Run smoke tests on startup (development only)
AUTO_SMOKE=0
